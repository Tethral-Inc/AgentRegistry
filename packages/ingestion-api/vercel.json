{
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm --filter @acr/shared build && pnpm --filter @acr/intelligence build",
  "rewrites": [
    { "source": "/lookup", "destination": "/public/lookup.html" },
    { "source": "/(.*)", "destination": "/api/[[...route]]" }
  ]
}
