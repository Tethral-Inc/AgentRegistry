COCKROACH_CONNECTION_STRING=postgresql://user:pass@host:26257/acr?sslmode=verify-full
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
AWS_REGION=us-east-1
TETHRAL_SIGNING_KEY_SEED=
SLACK_WEBHOOK_URL=
ACR_API_URL=https://acr.nfkey.ai
ACR_RESOLVER_URL=https://acr.nfkey.ai
INTERNAL_QUERY_SECRET=          # generate: openssl rand -hex 16
CRON_SECRET=                    # generate: openssl rand -hex 32 (Vercel + GH Actions)
CHURN_CHECK_ENABLED=            # default true; set false to disable IP/agent-id churn defense (receipt emitters)
CHURN_THRESHOLD_PER_IP_HOUR=    # default 50; tune after reviewing shadow-mode logs

# /register hardening (000022). Separate vars so the receipt-side and
# register-side defenses can be tuned independently.
REGISTER_POP_REQUIRED=                 # default true; set 'false' ONLY in local dev to bypass PoP — production must leave unset
REGISTER_CHURN_CHECK_ENABLED=          # default true; per-IP register churn defense
REGISTER_CHURN_THRESHOLD_PER_IP_HOUR=  # default 100; first rejected count (>=) per IP per hour
